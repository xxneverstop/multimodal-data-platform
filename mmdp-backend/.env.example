# ============================================
# MMDP Environment Variables
# Copy this file to .env and fill in real values
# This file IS committed to git
# ============================================

# Database connection (inside Docker network, hostname = mmdp-mysql)
MMDP_DB_URL=jdbc:mysql://mmdp-mysql:3306/mmdp_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai
MMDP_DB_USERNAME=root
MMDP_DB_PASSWORD=change_me

# Storage provider: Aliyun OSS
MMDP_STORAGE_DEFAULT_PROVIDER=OSS
MMDP_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
MMDP_OSS_ACCESS_KEY_ID=your_access_key_id_here
MMDP_OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
MMDP_OSS_BUCKET=your_bucket_name_here
MMDP_OSS_REGION=cn-hangzhou
MMDP_OSS_STS_ROLE_ARN=acs:ram::1234567890123456:role/your-mmdp-upload-role
MMDP_OSS_STS_ROLE_SESSION_NAME=mmdp-direct-upload
MMDP_OSS_STS_DURATION_SECONDS=900
