# ============================================
# mmdp-worker 本地开发环境变量模板
# 复制为 .env 并填入真实值。不提交 Git。
# ============================================

# ---- OSS 密钥（必填，与后端共用同一套）----
MMDP_OSS_ACCESS_KEY_ID=<你的AccessKey ID>
MMDP_OSS_ACCESS_KEY_SECRET=<你的AccessKey Secret>
MMDP_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
MMDP_OSS_BUCKET=mmdp-test
MMDP_OSS_REGION=cn-hangzhou

# ---- Worker 连接后端 ----
# 本地后端运行在 localhost:19021，默认值恰好正确，可不写
# MMDP_BACKEND_URL=http://localhost:19021

# ---- 本地路径（Windows 必须覆盖，config.py 默认值是 Linux 路径）----
# 临时工作目录
MMDP_WORKER_WORK_DIR=D:\tmp\mmdp-worker
# SMPL-H 人体模型目录（用于 MOTION_PHYSICS_METRICS_V2）
MMDP_SMPL_MODEL_DIR=D:\models\smplh

# ---- 可选 ----
# 轮询间隔（秒），默认 5
# MMDP_WORKER_POLL_INTERVAL=5
# 物理指标计算设备，默认 cpu
# MMDP_PHYSICS_DEVICE=cpu
